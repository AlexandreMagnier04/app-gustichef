NODE_ENV=development

# BDD et Drizzle
DATABASE_URL=postgresql://user:password@localhost:5432/mydb
PORT_DB=port_db
POSTGRES_USER=postgres_user
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=postgres_db
ORIGIN=origin_url

# Google OAuth
GOOGLE_CLIENT_ID=google_client_id
GOOGLE_CLIENT_SECRET=google_client_secret


# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=better_auth_secret

# Stripe (test mode)
STRIPE_SECRET_KEY=sk_test_...
PUBLIC_STRIPE_KEY=pk_test_...

# SMTP — en dev utilise Mailpit (UI sur http://localhost:8025)
# L'app se connecte au service Docker "mailpit" sans auth
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Gustichef <no-reply@gustichef.local>

# MinIO (stockage S3-compatible local)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_BUCKET=gustichef
# URL publique exposée au navigateur (peut différer en prod : ex. https://cdn.gustichef.fr)
MINIO_PUBLIC_URL=http://localhost:9000
